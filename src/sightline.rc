// sightline.rc — application icon resource
// Compiled by windres; linked into SightlinePlayer.exe.
// favicon.ico must exist at src/favicon.ico relative to project root.
// Resource ID 1 is read at runtime by WinMain via LoadImageA(hInst,
// MAKEINTRESOURCEA(1), IMAGE_ICON, ...) — works on XP SP3 x86 through Win11.

#include <windows.h>

1 ICON "src/favicon.ico"
